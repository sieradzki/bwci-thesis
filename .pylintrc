# Pylint configuration for the BWCI thesis project.

[MAIN]
ignore=.venv,data,outputs,_local_archive
ignore-patterns=
persistent=no
load-plugins=
jobs=4
unsafe-load-any-extension=no

[MESSAGES CONTROL]
confidence=
disable=R,
        abstract-method,
        arguments-differ,
        attribute-defined-outside-init,
        c-extension-no-member,
        consider-using-enumerate,
        fixme,
        global-statement,
        import-error,
        import-self,
        import-star-module-level,
        invalid-str-codec,
        locally-disabled,
        missing-module-docstring,
        no-init,
        no-member,
        no-name-in-module,
        no-self-use,
        protected-access,
        suppressed-message,
        trailing-newlines,
        unnecessary-pass,
        useless-suppression,
        wrong-import-order,
        W0105,
        W1203

[REPORTS]
output-format=text
reports=no
evaluation=10.0 - ((float(5 * error + warning + refactor + convention) / statement) * 10)

[BASIC]
good-names=
  ,_
  ,df
  ,i
  ,j
  ,id
  ,pd
  ,np

bad-names=
name-group=
include-naming-hint=no
function-rgx=^(?:(?P<exempt>setUp|tearDown)|(?P<snake_case>_?[a-z][a-z0-9_]*))$
variable-rgx=^[a-z][a-z0-9_]*$
const-rgx=^(_?[A-Z][A-Z0-9_]*|__[a-z0-9_]+__|_?[a-z][a-z0-9_]*)$
attr-rgx=^_{0,2}[a-z][a-z0-9_]*$
argument-rgx=^[a-z][a-z0-9_]*$
class-attribute-rgx=^(_?[A-Z][A-Z0-9_]*|__[a-z0-9_]+__|_?[a-z][a-z0-9_]*)$
inlinevar-rgx=^[a-z][a-z0-9_]*$
class-rgx=^_?[A-Z][a-zA-Z0-9]*$
method-rgx=^_{0,2}[a-z][a-z0-9_]*$
no-docstring-rgx=(__.*__|main|test.*|.*test|.*Test)$
docstring-min-length=12

[TYPECHECK]
contextmanager-decorators=contextlib.contextmanager
ignored-modules=
ignored-classes=optparse.Values,thread._local,_thread._local
generated-members=

[FORMAT]
max-line-length=150
ignore-long-lines=(?x)(
  ^\s*(\#\ )?<?https?://\S+>?$|
  ^\s*(from\s+\S+\s+)?import\s+.+$)
single-line-if-stmt=no
max-module-lines=99999
indent-string='  '
indent-after-paren=4
expected-line-ending-format=

[MISCELLANEOUS]
notes=TODO

[STRING]
check-quote-consistency=yes

[VARIABLES]
init-import=no
dummy-variables-rgx=^\*{0,2}(_$|unused_|dummy_)
additional-builtins=
callbacks=cb_,_cb
redefining-builtins-modules=functools

[LOGGING]
logging-modules=logging

[SIMILARITIES]
min-similarity-lines=4
ignore-comments=yes
ignore-docstrings=yes
ignore-imports=no

[SPELLING]
spelling-dict=
spelling-ignore-words=
spelling-private-dict-file=
spelling-store-unknown-words=no

[IMPORTS]
deprecated-modules=regsub,
                   TERMIOS,
                   Bastion,
                   rexec,
                   sets
import-graph=
ext-import-graph=
int-import-graph=
known-standard-library=
known-third-party=pandas,numpy,sklearn,matplotlib,seaborn,scipy,jupyter,pyarrow
analyse-fallback-blocks=no

[CLASSES]
defining-attr-methods=__init__,
                      __new__,
                      setUp
exclude-protected=_asdict,
                  _fields,
                  _replace,
                  _source,
                  _make
valid-classmethod-first-arg=cls,
                            class_
valid-metaclass-classmethod-first-arg=mcs
